{
  "name": "pacher-studio",
  "version": "0.1.0",
  "description": "pacherでAHCのテストケース実行を支援するためのWebアプリです",
  "scripts": {
    "dev": "yarn server",
    "dev:renderer": "vite",
    "server": "nodemon --watch src/server --exec ts-node src/server/server.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --check \"./src/**/*.{ts,tsx,js,jsx,json,css,html}\"",
    "format:fix": "prettier --write \"./src/**/*.{ts,tsx,js,jsx,json,css,html}\""
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.1.1",
    "@mui/material": "^7.1.1",
    "allotment": "^1.20.4",
    "cheerio": "^1.1.0",
    "express": "^5.2.1",
    "glob": "^11.0.3",
    "mathjs": "^14.5.3",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "recharts": "^3.0.2",
    "smol-toml": "^1.3.4",
    "uuid": "^11.1.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/mathjs": "^9.4.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^8.52.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vite": "^4.0.0"
  },
  "author": "yunix-kyopro",
  "license": "UNLICENSED",
  "private": true
}